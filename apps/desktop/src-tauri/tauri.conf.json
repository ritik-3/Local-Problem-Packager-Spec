{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local Problem Packager",
  "version": "0.1.0",
  "identifier": "com.localproblem.packager",
  "build": {
    "beforeDevCommand": "pnpm --dir .. dev",
    "beforeBuildCommand": "pnpm --dir .. build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Local Problem Packager",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
